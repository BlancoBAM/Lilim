{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lilim",
  "version": "0.1.0",
  "identifier": "com.lilith.lilim-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lilim",
        "width": 420,
        "height": 700,
        "minWidth": 380,
        "minHeight": 500,
        "maxWidth": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": false,
        "x": null,
        "y": null,
        "shadow": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
